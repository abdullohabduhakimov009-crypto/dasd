{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (admin, client, or engineer).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client", "engineer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paymentDetails": { "$ref": "PaymentDetails" }
      },
      "required": ["uid", "email", "role"]
    },
    "PaymentDetails": {
      "title": "PaymentDetails",
      "description": "Bank account details for an engineer.",
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "bankName": { "type": "string" },
        "accountHolder": { "type": "string" },
        "accountNumber": { "type": "string" },
        "swiftCode": { "type": "string" },
        "routingNumber": { "type": "string" },
        "bankAddress": { "type": "string" }
      }
    },
    "Ticket": {
      "title": "Ticket",
      "description": "A service ticket logged by a client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientUid": { "type": "string" },
        "subject": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "completed", "cancelled"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Job": {
      "title": "Job",
      "description": "A job assigned to an engineer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ticketId": { "type": "string" },
        "engineerUid": { "type": "string" },
        "status": { "type": "string", "enum": ["assigned", "in-progress", "completed"] },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Service tickets."
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Assigned jobs."
    }
  }
}
