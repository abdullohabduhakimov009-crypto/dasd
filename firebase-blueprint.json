{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (Engineer, Client, or Admin)",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["engineer", "client", "admin"], "description": "User role" },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "country": { "type": "object", "description": "Country information" },
        "city": { "type": "object", "description": "City information" },
        "specializations": { "type": "array", "items": { "type": "string" }, "description": "Engineer specializations" },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "Engineer skills" },
        "experience": { "type": "string", "description": "Years of experience" },
        "hourlyRate": { "type": "string", "description": "Hourly rate" },
        "halfDayRate": { "type": "string", "description": "Half day rate" },
        "fullDayRate": { "type": "string", "description": "Full day rate" },
        "currency": { "type": "string", "description": "Currency code" },
        "bio": { "type": "string", "description": "User biography" },
        "phoneNumber": { "type": "string", "description": "Phone number" },
        "whatsappNumber": { "type": "string", "description": "WhatsApp number" },
        "linkedin": { "type": "string", "description": "LinkedIn profile" },
        "facebook": { "type": "string", "description": "Facebook profile" },
        "cvFile": { "type": "string", "description": "URL to CV file" },
        "idFile": { "type": "string", "description": "URL to ID file" },
        "paymentDetails": { "type": "object", "description": "Bank account details" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["email", "role"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "A service ticket logged by a client",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Ticket title" },
        "description": { "type": "string", "description": "Detailed description" },
        "status": { "type": "string", "enum": ["Open", "Assigned", "In Progress", "Completed", "Cancelled"], "description": "Ticket status" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"], "description": "Ticket priority" },
        "clientId": { "type": "string", "description": "UID of the client who created the ticket" },
        "engineerId": { "type": "string", "description": "UID of the engineer assigned to the ticket" },
        "serviceType": { "type": "string", "description": "Type of service requested" },
        "country": { "type": "string", "description": "Country of service" },
        "city": { "type": "string", "description": "City of service" },
        "location": { "type": "string", "description": "Full location address" },
        "contactEmail": { "type": "string", "format": "email", "description": "Contact email for the ticket" },
        "contactPhone": { "type": "string", "description": "Contact phone for the ticket" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Ticket creation time" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update time" }
      },
      "required": ["title", "clientId", "status"]
    },
    "Job": {
      "title": "Job",
      "description": "A completed or active job",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "JobPosting": {
      "title": "Job Posting",
      "description": "A job opportunity posted by an admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A billing invoice",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "amount": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Quotation": {
      "title": "Quotation",
      "description": "A service quotation",
      "type": "object",
      "properties": {
        "amount": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Opportunity": {
      "title": "Opportunity",
      "description": "A business opportunity",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "A system activity log",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "PaymentAdvice": {
      "title": "Payment Advice",
      "description": "Payment advice submitted by a client",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "amount": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Presence": {
      "title": "Presence",
      "description": "User presence status",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      }
    },
    "Application": {
      "title": "Application",
      "description": "An application by an engineer for a job",
      "type": "object",
      "properties": {
        "jobId": { "type": "string", "description": "ID of the job" },
        "engineerId": { "type": "string", "description": "UID of the engineer" },
        "status": { "type": "string", "enum": ["Pending", "Accepted", "Rejected"], "description": "Application status" },
        "appliedAt": { "type": "string", "format": "date-time", "description": "Application time" }
      },
      "required": ["jobId", "engineerId", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "UID of the sender" },
        "receiverId": { "type": "string", "description": "UID of the receiver" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time sent" },
        "read": { "type": "boolean", "description": "Whether the message has been read" }
      },
      "required": ["senderId", "receiverId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/tickets/{ticketId}": { "schema": "Ticket", "description": "Service tickets" },
    "/jobs/{jobId}": { "schema": "Job", "description": "Completed or active jobs" },
    "/job_postings/{jobPostingId}": { "schema": "JobPosting", "description": "Job opportunities" },
    "/invoices/{invoiceId}": { "schema": "Invoice", "description": "Billing invoices" },
    "/quotations/{quotationId}": { "schema": "Quotation", "description": "Service quotations" },
    "/opportunities/{opportunityId}": { "schema": "Opportunity", "description": "Business opportunities" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "System notifications" },
    "/users/{userId}/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/activities/{activityId}": { "schema": "Activity", "description": "System activity logs" },
    "/payment_advice/{adviceId}": { "schema": "PaymentAdvice", "description": "Payment advice submissions" },
    "/presence/{presenceId}": { "schema": "Presence", "description": "User presence status" },
    "/applications/{applicationId}": { "schema": "Application", "description": "Job applications" },
    "/messages/{messageId}": { "schema": "Message", "description": "Chat messages" }
  }
}
